{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Redirect the `@tauri-apps/*` imports to the pywebview compat shims
       (mirrors the Vite aliases so `tsc` resolves them too). */
    "baseUrl": ".",
    "paths": {
      "@tauri-apps/api/core": ["./src/shims/tauri/core.ts"],
      "@tauri-apps/api/window": ["./src/shims/tauri/window.ts"],
      "@tauri-apps/api/event": ["./src/shims/tauri/event.ts"],
      "@tauri-apps/api/webview": ["./src/shims/tauri/webview.ts"],
      "@tauri-apps/plugin-dialog": ["./src/shims/tauri/dialog.ts"],
      "@tauri-apps/plugin-opener": ["./src/shims/tauri/opener.ts"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
